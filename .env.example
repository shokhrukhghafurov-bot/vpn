PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inet
JWT_SECRET=replace_me
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=change_me
CORS_ORIGINS=*

APP_NAME=INET
APP_ENV=production
APP_LANGS=ru,en
APP_BASE_URL=https://your-domain.com
BACKEND_BASE_URL=https://your-domain.com
ADMIN_PANEL_BASE_URL=https://your-admin-domain.com
