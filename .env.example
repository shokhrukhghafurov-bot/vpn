PLAN_MONTHLY_3_ENABLED=true
PLAN_MONTHLY_3_CODE=plan-monthly-3-devices
PLAN_MONTHLY_3_NAME_RU=1 месяц · 3 устройства
PLAN_MONTHLY_3_NAME_EN=1 month · 3 devices
