HIDDIFY_IMPORT_NAME=INET Subscription
SUPPORT_TELEGRAM_URL=https://t.me/your_admin
BOT_NAME=INET Bot
BOT_USERNAME=inet_bot
BOT_TOKEN=

AUTH_DEV_LOGIN_CODE=111111
AUTH_ALLOW_DEV_CODE=true
AUTH_CODE_ISSUER_SECRET=

# Leave empty for personal-per-user subscriptions only.
# Enable legacy shared token mode only if you explicitly need backward compatibility.
SUBSCRIPTION_TOKEN=
LEGACY_GLOBAL_SUBSCRIPTION_TOKEN_ENABLED=false

VPN_ENGINE=nekobox
VLESS_SERVER=
VLESS_PORT=443
VLESS_UUID=
VLESS_TRANSPORT=tcp
VLESS_SECURITY=reality
VLESS_FLOW=xtls-rprx-vision
VLESS_SNI=www.cloudflare.com
VLESS_HOST=
VLESS_PATH=
VLESS_SERVICE_NAME=
VLESS_PUBLIC_KEY=
VLESS_SHORT_ID=
VLESS_FINGERPRINT=chrome
VLESS_ALLOW_INSECURE=false
VLESS_DNS_SERVERS=1.1.1.1,8.8.8.8
VLESS_ALPN=
VLESS_DOMAIN_RESOLVER=dns-remote
VLESS_PACKET_ENCODING=xudp
VLESS_MTU=1400

RU_LTE_SOURCE_URLS=https://raw.githubusercontent.com/igareck/vpn-configs-for-russia/main/Vless-Reality-White-Lists-Rus-Mobile.txt,https://raw.githubusercontent.com/igareck/vpn-configs-for-russia/main/Vless-Reality-White-Lists-Rus-Mobile-2.txt
RU_LTE_REFRESH_ON_STARTUP=false
RU_LTE_AUTO_REFRESH_ENABLED=false
RU_LTE_AUTO_REFRESH_MINUTES=30
RU_LTE_AUTO_REFRESH_TIMEOUT_SEC=600
RU_LTE_MAX_CANDIDATES=4
RU_LTE_TEST_LIMIT=40
RU_LTE_CONNECT_TIMEOUT_SEC=4
RU_LTE_ALLOWED_TRANSPORTS=xhttp,grpc,ws

VPN_DEFAULT_DEVICE_LIMIT=1
VPN_MAX_DEVICES_PER_ACCOUNT=3
VPN_MAINTENANCE_MODE=false
VPN_NEW_ACTIVATIONS_ENABLED=true
VPN_SETTINGS_EDITABLE=false

PLAN_DAILY_ENABLED=true
PLAN_DAILY_CODE=plan-daily
PLAN_DAILY_NAME_RU=1 день · 1 устройство
PLAN_DAILY_NAME_EN=1 day · 1 device
PLAN_DAILY_PRICE_RUB=59

PLAN_MONTHLY_1_ENABLED=true
PLAN_MONTHLY_1_CODE=plan-monthly-1-device
PLAN_MONTHLY_1_NAME_RU=1 месяц · 1 устройство
PLAN_MONTHLY_1_NAME_EN=1 month · 1 device
