{
  "log": { "level": "info" },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        { "name": "ru-lte-user", "uuid": "PASTE_RU_UUID", "flow": "xtls-rprx-vision" }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.cloudflare.com",
        "reality": {
          "enabled": true,
          "handshake": { "server": "www.cloudflare.com", "server_port": 443 },
          "private_key": "PASTE_RU_REALITY_PRIVATE_KEY",
          "short_id": ["abcd1234"]
        }
      }
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "mobile-upstream",
      "server": "RU_PROVIDER_HOST",
      "server_port": 10000,
      "version": "5",
      "username": "RU_PROVIDER_USER",
      "password": "RU_PROVIDER_PASS",
      "network": ["tcp", "udp"]
    }
  ],
  "route": {
    "final": "mobile-upstream",
    "auto_detect_interface": true
  }
}
